# .gitignore for Rust projects
# Compiled source files
/target/

# Temporary files
**/*.rs.bk

# IDE and editor files
/.vscode/
*.swp
*.swo
*.swn
*.bak
*.tmp
*.temp

# OS generated files
.DS_Store
Thumbs.db

# Cargo package files
Cargo.lock

# By default, don't ignore Cargo.lock for libraries, but ignore for binaries
# Uncomment the next line if this is a binary project
# Cargo.lock

# Misc
*.log

# MCP server cache (if used)
.rust-docs-mcp/
~/.rust-docs-mcp/

#other
aralez
pingapp